spring.application.name=GyanSetu
server.port=8080

# ================= DATABASE =================
# Replace with your local/prod DB settings (Neon PostgreSQL)
spring.datasource.url=jdbc:postgresql://ep-your-name.region.neon.tech/neondb?sslmode=require
spring.datasource.username=neondb_owner
spring.datasource.password=YOUR_PASSWORD_HERE

spring.datasource.driver-class-name=org.postgresql.Driver

# ================= JPA =================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
# ================= JWT =================
# Use a long random string for production!
app.jwt.secret=REPLACE_WITH_YOUR_SECRET_KEY
app.jwt.expiration-millis=31536000000

# ================= CORS =================
app.cors.allowed-origins=http://localhost:5173

# ================= GROQ AI =================
groq.api.key=YOUR_GROQ_API_KEY
